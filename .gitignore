# ── vcs runtime data ──────────────────────────────────────────────────────
# .vcs/ is the agent's local store (like .git/).  It is NOT committed to git.
# Each machine/agent maintains its own local store.
# To share state between machines use: vcs push/pull <hub-url>
.vcs/

# calculator demo — live example, not committed
examples/calculator/

# vcs-run runtime state — regenerated by vcs-run.js on each start
vcs.run.lock.json
